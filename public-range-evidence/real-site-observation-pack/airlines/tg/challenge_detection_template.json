{
  "schema_version": "challenge-detection-template/v1",
  "target": "tg",
  "brand_name": "Thai Airways",
  "live_observation_status": "NOT_RUN_NO_AUTHORIZATION_INPUT",
  "authorization_required_before_capture": true,
  "allowed_scope": "public homepage observation only",
  "stop_conditions": [
    "captcha_present",
    "waf_or_block_page_present",
    "login_required",
    "booking_or_payment_flow_entered",
    "account_or_order_surface_entered"
  ],
  "fields_to_record_when_authorized": [
    "challenge_marker_type",
    "challenge_url_pattern_redacted",
    "http_status",
    "redacted_response_marker",
    "timestamp_utc"
  ],
  "forbidden_fields": [
    "captcha_solution",
    "clearance_cookie_value",
    "risk_token_value",
    "raw_cookie",
    "pii"
  ]
}
