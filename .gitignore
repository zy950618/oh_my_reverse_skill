# CI 评分输出（每次 workflow 跑后会重新生成）
.ci-out/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/
env/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Node/frontend 本地依赖和构建产物
node_modules/
dist/
build/
coverage/
htmlcov/

# Playwright/浏览器自动化本地产物
playwright-report/
test-results/
blob-report/
.playwright/
.auth/
storage-state*.json
*.storage-state.json
trace.zip
*.trace.zip
*.webm
*.mp4

# 浏览器 profile / user-data-dir / 本地会话状态
browser-profiles/
.browser-profiles/
user-data-dir/
**/user-data-dir/
profiles/
.profiles/

# Stop hook 校准数据(本地分析用,不入 git)
tools/.reminder-stats.jsonl

# Claude Code 本地权限缓存
.claude/settings.local.json

# Replay 临时产物(每次本地跑都会重新生成,不入 git)
站点经验库/*/fixtures/actual/

# Recording 原始抓包(30 天后删除,体积大,不入 git)
站点经验库/*/fixtures/recordings/

# 不入 git 的抓包/事件/响应体 dump
*.har
*.body
*.dump
*.tmp
*.bak
站点经验库/*/fixtures/recordings/*.har
站点经验库/*/fixtures/recordings/*.jsonl

# 本地 run/capture 输出目录；正式经验只写脱敏摘要和 fixtures meta
runs/
captures/
.captures/
recordings/
local-runs/

# 本地项目交付物(只在本机/交付包保留,不上传 GitHub)
交付项目/

# 本地实战项目库: GitHub 只保留 README、模板和通用规范
站点经验库/*/
!站点经验库/_templates/
!站点经验库/_templates/**
!站点经验库/_archive/
!站点经验库/_archive/stale-20260701/
!站点经验库/_archive/stale-20260701/**/
!站点经验库/_archive/stale-20260701/**/manifest.json
!站点经验库/local-governance.fixture/
!站点经验库/local-governance.fixture/**
!站点经验库/README.md

# 归档 stale fixture 只上传 manifest/hash，不上传过期三件套。
站点经验库/_archive/stale-20260701/**/*.req.json
站点经验库/_archive/stale-20260701/**/*.resp.json
站点经验库/_archive/stale-20260701/**/*.meta.yaml

逆向工程经验库/domains/*/
!逆向工程经验库/domains/_example.com/
!逆向工程经验库/domains/_example.com/**

验证码经验库/domains/*/
!验证码经验库/domains/_example.com/
!验证码经验库/domains/_example.com/**

# 本地运行/评分/抓包产物(每轮可再生成,不上传 GitHub)
metrics/

# Public range evidence: commit sanitized summaries only.
public-range-evidence/raw/
public-range-evidence/**/raw/
public-range-evidence/**/*.har
public-range-evidence/**/*.body
public-range-evidence/**/*.dump
