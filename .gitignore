# CI 评分输出（每次 workflow 跑后会重新生成）
.ci-out/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Stop hook 校准数据(本地分析用,不入 git)
tools/.reminder-stats.jsonl

# Claude Code 本地权限缓存
.claude/settings.local.json

# Replay 临时产物(每次本地跑都会重新生成,不入 git)
站点经验库/*/fixtures/actual/

# Recording 原始抓包(30 天后删除,体积大,不入 git 默认值,需要时按 domain 取消注释)
# 站点经验库/*/fixtures/recordings/

# 不入 git 的 recording 二进制(HAR/jsonl 单文件常 30MB+)
站点经验库/*/fixtures/recordings/*.har
站点经验库/*/fixtures/recordings/*.jsonl

# 本地项目交付物(只在本机/交付包保留,不上传 GitHub)
交付项目/

# 本地实战项目库: GitHub 只保留 README、模板和通用规范
站点经验库/*/
!站点经验库/_templates/
!站点经验库/_templates/**
!站点经验库/README.md

逆向工程经验库/domains/*/
!逆向工程经验库/domains/_example.com/
!逆向工程经验库/domains/_example.com/**

验证码经验库/domains/*/
!验证码经验库/domains/_example.com/
!验证码经验库/domains/_example.com/**

# 本地运行/评分/抓包产物(每轮可再生成,不上传 GitHub)
metrics/captures/
metrics/codex_score_current.json
